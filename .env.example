# ---------------------------------------------------------------------------
# eks-gitops-starter configuration
#
#   cp .env.example .env   &&   edit   &&   ./setup.sh
#
# Everything under "Optional" defaults to OFF. The local kind path
# (`task kind-up`) needs NONE of these set.
# ---------------------------------------------------------------------------

# ============================ Required for AWS =============================
# Leave blank to work purely locally on kind.

# Your 12-digit AWS account ID (used in IAM/ECR ARNs).
AWS_ACCOUNT_ID=

# AWS region for all resources.
AWS_REGION=eu-west-2

# The DNS zone you manage in Route53 (e.g. example.com). Apps get hostnames
# under this zone in staging/prod.
CLUSTER_DOMAIN=example.com

# The Git URL of THIS repository (your fork). Argo CD reconciles from here.
GITOPS_REPO_URL=https://github.com/your-org/eks-gitops-starter.git


# ============================ Optional: Tailscale =========================
# Private access to in-cluster services without public ingress.
# Set to true and provide the OAuth secret name to enable the Tailscale
# operator (delivered as a Kustomize component). Leave false to skip entirely.
ENABLE_TAILSCALE=false
# Name of the Secrets Manager secret holding Tailscale OAuth creds:
# TAILSCALE_OAUTH_SECRET=tailscale/oauth


# ============================ Optional: HCP Terraform =====================
# Remote state + runs via HCP Terraform (app.terraform.io).
# false (default) => state in S3 + DynamoDB (see setup.sh).
USE_HCP_BACKEND=false
# HCP organization name (only used when USE_HCP_BACKEND=true):
# HCP_ORG=your-hcp-org

# For the default S3 backend (USE_HCP_BACKEND=false), the bucket + lock table.
# setup.sh writes these into each environment's backend override.
TF_STATE_BUCKET=
TF_STATE_LOCK_TABLE=eks-gitops-starter-tf-locks
