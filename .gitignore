# Local config (never commit — holds account IDs, domains, secrets)
.env

# Terraform / OpenTofu
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl

# Generated by setup.sh (hold account IDs / user-specific values)
infra/environments/*/backend_override.tf
infra/environments/*/zz_generated.auto.tfvars

# Editors / OS
.idea/
.vscode/
.DS_Store

# Python (tooling, if any)
__pycache__/
*.py[cod]
.venv/
